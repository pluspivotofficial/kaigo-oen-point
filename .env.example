# Supabase (self-hosted, Tokyo region)
# ローカル開発: このファイルを `.env` にコピーして値を埋める
# Vercel本番:   Vercel Dashboard > Settings > Environment Variables に同じキーで登録

# Supabase Project URL (例: https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase Project Reference (URLのサブドメイン部分)
VITE_SUPABASE_PROJECT_ID=

# Supabase Publishable (anon) Key — 公開可、フロントエンドに埋め込まれる
VITE_SUPABASE_PUBLISHABLE_KEY=
